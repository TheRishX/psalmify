{
  "entities": {
    "Song": {
      "title": "Song",
      "description": "A worship or praise track with raw and formatted lyrics.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "album": { "type": "string" },
        "genre": { "type": "string" },
        "duration": { "type": "string" },
        "rawLyrics": { "type": "string" },
        "formattedLyrics": { "type": "array" },
        "coverUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "submittedBy": { "type": "string" },
        "submittedByName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "artist", "rawLyrics", "status", "submittedBy", "createdAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A curated collection of lyric tracks.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "genre": { "type": "string" },
        "coverUrl": { "type": "string" },
        "songIds": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "submittedBy": { "type": "string" },
        "submittedByName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "description", "status", "submittedBy", "createdAt"]
    },
    "Genre": {
      "title": "Genre",
      "description": "A dynamic musical catalog genre.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Details of the user, their church, location and registered contact details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "churchName": { "type": "string" },
        "churchLocation": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "additionalData": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Collection of worship songs."
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "Collection of curated themed song lists."
    },
    "/genres/{genreId}": {
      "schema": "Genre",
      "description": "Dynamic playlist & submission genres."
    },
    "/user_profiles/{uid}": {
      "schema": "UserProfile",
      "description": "User profile collection, editable by owners and viewable by admin."
    }
  }
}
