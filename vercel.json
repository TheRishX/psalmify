{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?__vercel_api_path=/api/$1"
    },
    {
      "source": "/auth/callback(.*)",
      "destination": "/api/index?__vercel_api_path=/auth/callback$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
